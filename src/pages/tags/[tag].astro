---
import Layout from '@layouts/Layout.astro';
import SectionByTag from '@components/SectionByTag.astro';
import { getPostsByTag } from '@libs/postsByTag';

export async function getStaticPaths() {
  const tags = await getPostsByTag();

  return tags.map((tag) => {
    return {
      params: { tag: tag.name },
      props: { posts: tag.posts },
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<Layout title={tag} class="tag">
  <SectionByTag title={tag} posts={posts} href={`/tags/${tag}/`} showCount />
</Layout>
