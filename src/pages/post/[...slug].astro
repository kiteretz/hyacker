---
// .mdのfrontmatterを増やす場合は、content.config.tsも更新する
import { type CollectionEntry, render } from 'astro:content';

import Layout from '@layouts/Layout.astro';

import SectionByTag from '@components/SectionByTag.astro';
import SocialIcon from '@components/SocialIcon.astro';
import TableOfContents from '@components/TableOfContents.astro';

import { getSortedPosts } from '@libs/sortedPosts';

import { formatDate } from '@utils/formatDate';

export async function getStaticPaths() {
  const sortedPosts = await getSortedPosts();

  return sortedPosts.map((entry, index) => {
    const prev = index > 0 ? sortedPosts[index - 1] : null;
    const next = index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null;

    return {
      params: { slug: entry.id },
      props: { entry: entry, prev: prev, next: next },
    };
  });
}

interface Props {
  entry: CollectionEntry<'posts'>;
  prev: CollectionEntry<'posts'> | undefined;
  next: CollectionEntry<'posts'> | undefined;
}

const { entry } = Astro.props;
const { Content, headings = [] } = await render(entry);

const { title, description, pubDate, tags } = entry.data;
const currentTags = tags ?? [];

// Related posts: タグが1つ以上一致する記事を最大5件取得
const sortedPosts = await getSortedPosts();
const relatedPosts = sortedPosts
  .filter((p) => p.id !== entry.id && p.data.tags?.some((t: string) => currentTags.includes(t)))
  .slice(0, 5);

// h3見出し数を算出（左カラムのインデックス表示用）
const h3Headings = headings.filter((h) => h.depth === 3);
const headingCountStr = String(h3Headings.length || 1).padStart(2, '0');
---

<Layout title={title} description={description} class="post">
  <div class="grid gap-px font-inter">
    <div>
      <div class:list={['grid gap-px', 'grid-cols-1', 'xl:grid-cols-[16.625rem_1fr]']}>
        <!-- Left sidebar: Share + Heading Index -->
        <div class:list={['hidden', 'xl:flex xl:flex-col xl:bg-white']} data-js-sticky-sidebar>
          <div
            class="flex h-[max(calc(100svh-var(--header-height)),30rem)] flex-col items-end justify-between px-32 py-32 pb-8"
            data-js-sticky-sidebar-inner
          >
            <!-- Share icons -->
            <div class="pointer-events-auto flex flex-col items-end">
              <SocialIcon />
            </div>
            <!-- Heading index -->
            <div
              class="text-fg-800 flex flex-col font-space-grotesk text-160 leading-none font-bold slashed-zero tabular-nums opacity-10"
            >
              <p class="relative top-16" data-section-current>01</p>
              <p data-heading-total>
                {headingCountStr}
              </p>
            </div>
          </div>
        </div>

        <!-- Content area: inner grid -->
        <div class:list={['grid gap-px', 'grid-cols-1', 'xl:grid-cols-4 xl:grid-rows-[auto_1fr]', '2xl:grid-cols-5']}>
          <!-- Article Header -->
          <div
            class:list={[
              'bg-white p-16',
              'md:p-32',
              'xl:col-[1/-2] xl:row-1 xl:flex xl:items-center xl:justify-center',
            ]}
          >
            <h1 class="w-full max-w-5xl font-palt text-28 leading-normal font-bold md:text-40">
              {title}
            </h1>
          </div>

          <!-- Published + Tags -->
          <div
            class:list={[
              'flex flex-wrap gap-16 bg-white p-16',
              'md:flex-col md:gap-24 md:px-24 md:py-32',
              'xl:col-[-2/-1] xl:row-1',
            ]}
          >
            <div class="flex flex-col gap-12">
              <p class="text-fg-400 font-inter text-14 leading-none uppercase">Published</p>
              <p class="font-space-grotesk text-16 leading-tight">
                <time datetime={pubDate.toISOString()} data-pagefind-meta="pubDate">{formatDate(pubDate)}</time>
              </p>
            </div>
            <div class="flex flex-col gap-12">
              <p class="text-fg-400 font-inter text-14 leading-none uppercase">Tags</p>
              <p class="text-16 leading-tight">
                {
                  currentTags.map((tag: string, i: number) => (
                    <>
                      <a href={`/tags/${tag}`} class="hover:underline">
                        {tag}
                      </a>
                      {i < currentTags.length - 1 && ', '}
                    </>
                  ))
                }
              </p>
            </div>
          </div>

          <!-- Mobile: Share icons -->
          <div class="flex items-center justify-end bg-white px-16 py-8 xl:hidden">
            <SocialIcon />
          </div>

          <!-- Article Body -->
          <div class:list={['bg-white px-16 py-32', 'md:p-32', 'xl:col-[1/-2] xl:row-2 xl:flex xl:justify-center']}>
            <div class="prose w-full" data-pagefind-body>
              <Content />
            </div>
          </div>

          <!-- TOC + Ad -->
          <div class:list={['bg-white', 'xl:relative xl:col-[-2/-1] xl:row-2']}>
            <div
              class="pointer-events-none sticky top-(--header-height) hidden h-[calc(100svh-var(--header-height))] xl:flex xl:flex-col xl:justify-between"
            >
              <!-- TOC -->
              <div class="pointer-events-auto flex flex-col gap-16 overflow-y-auto px-24 py-32">
                <p class="text-fg-400 font-inter text-14 leading-none uppercase">Table of contents</p>
                <TableOfContents headings={headings} />
              </div>
              <!-- Ad card -->
              <div class="border-fg-800 pointer-events-auto sticky bottom-0 -translate-y-px border-t bg-white p-8">
                <div class="flex flex-col gap-4">
                  <div class="flex items-center justify-between p-8 leading-tight">
                    <p class="text-fg-400 font-inter text-14">AD, PR</p>
                  </div>
                  <img src="https://placehold.co/250x188" alt="" class="w-full rounded-8" />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Related Posts -->
    <SectionByTag title="Related" posts={relatedPosts.slice(0, 5)} />
  </div>
</Layout>
