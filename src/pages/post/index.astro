---
import Layout from '@layouts/Layout.astro';

import SectionByTag from '@components/SectionByTag.astro';

import { getSortedPosts } from '@libs/sortedPosts';

const posts = await getSortedPosts();
---

<Layout title="All Posts" class="post-archive">
  <SectionByTag title="All Posts" posts={posts} showCount showAll />
</Layout>
