---
import Layout from '@layouts/Layout.astro';
import KV from '@components/KV.astro';
import SectionByTag from '@components/SectionByTag.astro';
import { getPostsByTag } from '@libs/postsByTag';
import type { SectionItem } from '@components/SectionByTag.astro';

const tags = await getPostsByTag();

// Editor's Picksを探す（タグがなければ undefined）
const editorsPicks = tags.find((t) => t.name === "Editor's Picks");

// Editor's Picksを除いた残りのタグを記事数の多い順に最大3つ取得
const otherTags = tags.filter((t) => t.name !== "Editor's Picks").slice(0, 3);

const sections: SectionItem[] = [
  ...(editorsPicks
    ? [
        {
          title: editorsPicks.name,
          // description: 'Editor’s Picks',
          href: `/tags/${editorsPicks.name}/`,
          posts: editorsPicks.posts,
        },
      ]
    : []),
  ...otherTags.map(({ name, posts }) => ({
    title: name,
    href: `/tags/${name}/`,
    posts,
  })),
];
---

<Layout>
  <KV
    title="The Encyclopedia <br />for Creators"
    subTitle="クリエイターのための百科事典"
    bgText="namehyacke<br />risfrom(hy<br />akka)+hack<br />erkiteretz"
  />
  {
    sections.map(({ title, posts, href }, index) => (
      <SectionByTag title={title} posts={posts} href={href} index={index + 1} />
    ))
  }
</Layout>
