---
import Layout from '@layouts/Layout.astro';
import KV from '@components/KV.astro';
import SectionByTag from '@components/SectionByTag.astro';
import { getPostsByTag } from '@libs/postsByTag';

const tags = await getPostsByTag();

// Editor's Picksを探す（タグがなければ undefined）
const editorsPicks = tags.find((t) => t.name === "Editor's Picks");
---

<Layout>
  <KV
    title="404<br />Page Not Found"
    subTitle="ページが見つかりません。<br />検索フォームをご利用ください。"
    bgText="404_not_fo<br />und.404_no<br />t_found.40<br />4_not_foun"
  />
  {
    editorsPicks && (
      <SectionByTag title="Editor's Picks" posts={editorsPicks.posts} href={`/tags/${editorsPicks.name}/`} />
    )
  }
</Layout>
