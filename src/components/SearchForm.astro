---
import { twMerge } from 'tailwind-merge';
import SearchInput from '@components/SearchInput';

export interface Props {
  className?: string;
  buttonClassName?: string;
  iconClassName?: string;
  inputClassName?: string;
}

const { className, buttonClassName, iconClassName, inputClassName } = Astro.props;
const isSearchPage = Astro.url.pathname === '/search/';
const shouldDisable = isSearchPage ? true : false;
---

<form action="/search/" method="get">
  <label class={twMerge('relative flex items-center', className)}>
    <SearchInput client:load className={inputClassName} />
    <button
      class={twMerge('absolute right-16 flex aspect-square w-32 shrink items-center justify-center', buttonClassName)}
      disabled={shouldDisable}
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 18 18" class={twMerge('w-12', iconClassName)}>
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M8.25 14.25a6 6 0 1 0 0-12 6 6 0 0 0 0 12Zm7.5 1.5-3.263-3.262"></path>
      </svg>
    </button>
  </label>
</form>

<script>
  import '@scripts/hoverSearchButton';
</script>
