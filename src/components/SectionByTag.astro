---
import Card from '@components/Card';
import { twMerge } from 'tailwind-merge';
import type { CollectionEntry } from 'astro:content';

export type SectionItem = {
  index?: number;
  href?: string;
  title: string;
  description?: string;
  posts: CollectionEntry<'posts'>[];
  showCount?: boolean;
};

interface Props extends SectionItem {}

const { title, posts, index, href = '#', showCount = false } = Astro.props;
const indexStr = index !== undefined ? String(index).padStart(2, '0') : '';
const countStr = String(posts.length).padStart(3, '0');
---

<section>
  <div class="mb-px grid xl:grid-cols-[16.625rem_1fr] xl:gap-px">
    <div class="max-xl:sticky max-xl:top-(--header-height) max-xl:border-b" data-js-sticky-sidebar>
      <a
        href={href}
        class={twMerge(
          'flex items-center justify-between bg-white p-16 font-inter font-palt leading-none',
          'xl:h-[max(calc(100svh-var(--header-height)),30rem)] xl:flex-col xl:items-start xl:p-32',
        )}
        data-js-sticky-sidebar-inner
      >
        <h2 class="text-32 leading-none font-semibold tracking-tighter xl:text-64 xl:writing-sideways-rl">{title}</h2>
        <p class="flex items-center gap-x-4 xl:relative">
          {
            showCount ? (
              <span>{countStr}</span>
            ) : (
              <>
                <span class="text-16 font-medium tracking-tight">View More</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  fill="none"
                  viewBox="0 0 24 24"
                  class="size-16"
                >
                  <path stroke="#171717" stroke-linejoin="bevel" stroke-width="2" d="M4 12h16m-8-8 8 8-8 8" />
                </svg>
              </>
            )
          }
          {
            indexStr && (
              <span class="hidden xl:absolute xl:bottom-0 xl:left-0 xl:block xl:font-space-grotesk xl:text-160 xl:leading-none xl:font-bold xl:text-neutral-800 xl:lining-nums xl:slashed-zero xl:tabular-nums xl:opacity-10">
                {indexStr}
              </span>
            )
          }
        </p>
      </a>
    </div>
    <div class="grid gap-px sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 2xl:grid-cols-5">
      {
        posts.slice(0, 15).map((post) => {
          return (
            <Card
              href={`/post/${post.id}`}
              title={post.data.title}
              date={post.data.pubDate}
              tags={post.data.tags ?? []}
              img={post.data.image?.url}
              client:load
            />
          );
        })
      }
    </div>
  </div>
</section>
